rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isApproved() {
      return isSignedIn() && (
        request.auth.token.email == 'jacsonmarcelo@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSubscribed == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
          get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.isSubscribed == true
        )
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jacsonmarcelo@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        )
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidFinancialEntry(data) {
      return data.keys().hasAll(['date', 'description', 'tableId', 'categoryId', 'amount', 'userId', 'createdAt'])
        && data.keys().size() == 7
        && data.date is string && data.date.size() <= 100
        && data.description is string && data.description.size() <= 200
        && data.tableId is string && data.tableId.size() <= 50
        && data.categoryId is string && data.categoryId.size() <= 100
        && data.amount is number
        && data.userId == request.auth.uid;
    }

    function isValidBudgetLimit(data) {
      return data.keys().hasAll(['categoryId', 'tableId', 'limitAmount', 'month', 'userId'])
        && data.keys().size() == 5
        && data.categoryId is string && data.categoryId.size() <= 100
        && data.tableId is string && data.tableId.size() <= 50
        && data.limitAmount is number
        && data.month is string && data.month.matches('^\\d{4}-\\d{2}$')
        && data.userId == request.auth.uid;
    }

    function isValidRecurringEntry(data) {
      return data.keys().hasAll(['description', 'tableId', 'categoryId', 'amount', 'dayOfMonth', 'userId', 'active'])
        && data.keys().size() == 7
        && data.description is string && data.description.size() <= 200
        && data.tableId is string && data.tableId.size() <= 50
        && data.categoryId is string && data.categoryId.size() <= 100
        && data.amount is number
        && data.dayOfMonth is int && data.dayOfMonth >= 1 && data.dayOfMonth <= 31
        && data.active is bool
        && data.userId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'isSubscribed', 'isAdmin', 'createdAt'])
        && data.keys().size() >= 5
        && data.email is string
        && data.isSubscribed is bool
        && data.isAdmin is bool;
    }

    function isValidAnalyticsEvent(data) {
      return data.keys().hasAll(['eventName', 'userId', 'timestamp', 'screen'])
        && (data.keys().size() == 4 || (data.keys().size() == 5 && data.keys().hasAll(['metadata'])))
        && data.eventName is string && data.eventName.size() <= 100
        && data.userId == request.auth.uid
        && data.screen is string && data.screen.size() <= 100
        && (data.keys().size() == 4 || data.metadata is map);
    }

    function isValidUserMetric(data) {
      return data.keys().hasAll(['userId', 'date', 'launchesCount', 'dashboardOpened', 'reportsOpened', 'activeToday', 'lastActivity'])
        && data.keys().size() == 7
        && data.userId == request.auth.uid
        && data.date is string && data.date.size() == 10
        && data.launchesCount is number
        && data.dashboardOpened is bool
        && data.reportsOpened is bool
        && data.activeToday is bool;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'rating', 'nps', 'mostUseful', 'difficulty', 'suggestion'])
        && data.keys().size() == 7
        && data.userId == request.auth.uid
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.nps is number && data.nps >= 0 && data.nps <= 10
        && data.mostUseful is list
        && data.difficulty is string && data.difficulty.size() <= 1000
        && data.suggestion is string && data.suggestion.size() <= 5000;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || (isSignedIn() && request.auth.token.email.lower() == userId.lower());
      allow list: if isAdmin();
      allow create: if (isOwner(userId) || isAdmin())
                    && (
                      isAdmin() || 
                      incoming().isSubscribed == false || 
                      (
                        exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) &&
                        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.isSubscribed == incoming().isSubscribed
                      )
                    )
                    && (isAdmin() || incoming().isAdmin == false || request.auth.token.email == 'jacsonmarcelo@gmail.com');
      allow update: if isAdmin() || (
        isOwner(userId) && 
        (
          incoming().isSubscribed == existing().isSubscribed || 
          (
            exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) &&
            get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.isSubscribed == incoming().isSubscribed
          )
        ) &&
        (incoming().isAdmin == existing().isAdmin)
      );
    }

    match /entries/{entryId} {
      allow create: if isApproved() && isValidFinancialEntry(incoming());
      allow update: if isApproved() && isOwner(existing().userId) && isValidFinancialEntry(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isApproved() && isOwner(existing().userId);
      allow get: if isApproved() && isOwner(existing().userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
    }

    match /budgets/{budgetId} {
      allow create: if isApproved() && isValidBudgetLimit(incoming());
      allow update: if isApproved() && isOwner(existing().userId) && isValidBudgetLimit(incoming())
                    && incoming().userId == existing().userId;
      allow delete: if isApproved() && isOwner(existing().userId);
      allow get: if isApproved() && isOwner(existing().userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
    }

    match /recurring/{recurringId} {
      allow create: if isApproved() && isValidRecurringEntry(incoming());
      allow update: if isApproved() && isOwner(existing().userId) && isValidRecurringEntry(incoming())
                    && incoming().userId == existing().userId;
      allow delete: if isApproved() && isOwner(existing().userId);
      allow get: if isApproved() && isOwner(existing().userId);
      allow list: if isApproved() && resource.data.userId == request.auth.uid;
    }

    match /analytics_events/{eventId} {
      allow create: if isSignedIn() && isValidAnalyticsEvent(incoming()) && incoming().userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
    }

    match /user_metrics/{metricId} {
      allow create: if isSignedIn() && isValidUserMetric(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidUserMetric(incoming()) && incoming().userId == request.auth.uid && existing().userId == request.auth.uid;
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming()) && incoming().userId == request.auth.uid;
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /auth_otps/{email} {
      allow read, write: if false; // Server-side only
    }

    // Optional: Add test document for connection check
    match /test/connection {
      allow get: if isSignedIn();
    }
  }
}
